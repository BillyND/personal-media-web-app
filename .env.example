APP_ENV=development
APP_PASSWORD=change-me
# APP_PASSWORD_HASH=
SESSION_SECRET=change-me-to-a-long-random-secret
DATA_DIR=./data
OUTPUT_DIR=./data/outputs
MAX_VIDEO_DURATION_SECONDS=900
MAX_DOWNLOAD_BYTES=524288000
COMMAND_TIMEOUT_SECONDS=300
JOB_STALE_MINUTES=120
AUTO_DELETE_DAYS=30
WHISPER_MODEL=base
WHISPER_COMPUTE_TYPE=int8
PIPER_BINARY_PATH=./runtime/bin/piper
PIPER_VOICE_PATH=./data/models/piper/en_US-ryan-medium.onnx
PIPER_CONFIG_PATH=./data/models/piper/en_US-ryan-medium.onnx.json
DEFAULT_TTS_VOICE_ID=en_US-ryan-medium
MAX_TTS_TEXT_LENGTH=5000
MAX_PREVIEW_BYTES=262144
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_SECONDS=300
